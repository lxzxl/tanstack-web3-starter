# WalletConnect / Reown project id — get one free at https://cloud.reown.com
# Needed for WalletConnect-based wallets. Browser-injected wallets (MetaMask etc.)
# work without it. Copy this file to `.env` and fill in the value.
VITE_WALLETCONNECT_PROJECT_ID=

# Server-side secret for signing SIWE session cookies (NOT exposed to the client —
# no VITE_ prefix). Dev uses an insecure fallback; set a long random value in your
# host's environment for production.
SESSION_SECRET=
